{
    "name": "switon/pool",
    "description": "Owner-scoped object pools with guard-based borrow and return for Switon Framework",
    "type": "library",
    "keywords": [
        "switon",
        "pooling",
        "connections",
        "resources"
    ],
    "homepage": "https://github.com/switon-php/pool",
    "license": "MIT",
    "authors": [
        {
            "name": "switon",
            "email": "admin@switon.dev"
        }
    ],
    "support": {
        "source": "https://github.com/switon-php/pool",
        "issues": "https://github.com/switon-php/pool/issues",
        "docs": "https://docs.switon.dev/latest/pool"
    },
    "require": {
        "php": ">=8.3",
        "psr/event-dispatcher": "^1.0",
        "switon/core": "^1.0",
        "switon/event": "^1.0",
        "switon/sync": "^1.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.0",
        "phpstan/extension-installer": "^1.4",
        "switon/testing": "^1.0"
    },
    "config": {
        "allow-plugins": {
            "switon/composer-extra": true,
            "phpstan/extension-installer": true
        }
    },
    "autoload": {
        "psr-4": {
            "Switon\\Pooling\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Switon\\Pooling\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "phpstan": "@php vendor/bin/phpstan analyse",
        "test": "@php vendor/bin/phpunit --configuration tests/phpunit.xml.dist --testsuite=all --display-deprecations --display-phpunit-notices"
    },
    "extra": {
        "phpstan": {
            "includes": [
                "phpstan-extension.neon"
            ]
        },
        "branch-alias": {
            "dev-dev": "1.0.x-dev"
        }
    }
}
